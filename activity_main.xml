<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:gravity="bottom">

    <!-- Expression (small, above) -->
    <TextView
        android:id="@+id/tvExpression"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp"
        android:text=""
        android:textColor="@color/text_secondary"
        android:textSize="18sp"
        android:gravity="end"
        android:singleLine="true"
        android:ellipsize="start"/>

    <!-- Main display -->
    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingBottom="16dp"
        android:text="0"
        android:textColor="@color/text_primary"
        android:textSize="64sp"
        android:gravity="end"
        android:singleLine="true"
        android:ellipsize="start"
        android:fontFamily="sans-serif-light"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A2A"/>

    <!-- Button grid -->
    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:stretchColumns="*">

        <!-- Row 1: C  +/-  %  ÷ -->
        <TableRow android:layout_weight="1">
            <Button android:id="@+id/btnClear"
                style="@style/Btn.Function"  android:text="C"   android:tag="C"      android:onClick="onButtonClick"/>
            <Button android:id="@+id/btnNegate"
                style="@style/Btn.Function"  android:text="+/−" android:tag="+/-"    android:onClick="onButtonClick"/>
            <Button android:id="@+id/btnPercent"
                style="@style/Btn.Function"  android:text="%"   android:tag="%"      android:onClick="onButtonClick"/>
            <Button android:id="@+id/btnDiv"
                style="@style/Btn.Operator"  android:text="÷"   android:tag="/"      android:onClick="onButtonClick"/>
        </TableRow>

        <!-- Row 2: 7  8  9  × -->
        <TableRow android:layout_weight="1">
            <Button style="@style/Btn.Number" android:text="7" android:tag="7" android:onClick="onButtonClick"/>
            <Button style="@style/Btn.Number" android:text="8" android:tag="8" android:onClick="onButtonClick"/>
            <Button style="@style/Btn.Number" android:text="9" android:tag="9" android:onClick="onButtonClick"/>
            <Button style="@style/Btn.Operator" android:text="×" android:tag="*" android:onClick="onButtonClick"/>
        </TableRow>

        <!-- Row 3: 4  5  6  − -->
        <TableRow android:layout_weight="1">
            <Button style="@style/Btn.Number" android:text="4" android:tag="4" android:onClick="onButtonClick"/>
            <Button style="@style/Btn.Number" android:text="5" android:tag="5" android:onClick="onButtonClick"/>
            <Button style="@style/Btn.Number" android:text="6" android:tag="6" android:onClick="onButtonClick"/>
            <Button style="@style/Btn.Operator" android:text="−" android:tag="-" android:onClick="onButtonClick"/>
        </TableRow>

        <!-- Row 4: 1  2  3  + -->
        <TableRow android:layout_weight="1">
            <Button style="@style/Btn.Number" android:text="1" android:tag="1" android:onClick="onButtonClick"/>
            <Button style="@style/Btn.Number" android:text="2" android:tag="2" android:onClick="onButtonClick"/>
            <Button style="@style/Btn.Number" android:text="3" android:tag="3" android:onClick="onButtonClick"/>
            <Button style="@style/Btn.Operator" android:text="+" android:tag="+" android:onClick="onButtonClick"/>
        </TableRow>

        <!-- Row 5: ⌫  0  .  = -->
        <TableRow android:layout_weight="1">
            <Button style="@style/Btn.Function" android:text="⌫"  android:tag="backspace" android:onClick="onButtonClick"/>
            <Button style="@style/Btn.Number"   android:text="0"   android:tag="0"         android:onClick="onButtonClick"/>
            <Button style="@style/Btn.Number"   android:text="."   android:tag="."         android:onClick="onButtonClick"/>
            <Button style="@style/Btn.Equals"   android:text="="   android:tag="="         android:onClick="onButtonClick"/>
        </TableRow>

    </TableLayout>
</LinearLayout>
