<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Calculator" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>

    <!-- Base button style -->
    <style name="Btn.Base" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">26sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">0dp</item>
        <item name="rippleColor">@color/text_secondary</item>
    </style>

    <style name="Btn.Number" parent="Btn.Base">
        <item name="backgroundTint">@color/btn_number</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Btn.Function" parent="Btn.Base">
        <item name="backgroundTint">@color/btn_function</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Btn.Operator" parent="Btn.Base">
        <item name="backgroundTint">@color/btn_operator</item>
        <item name="android:textColor">@color/text_on_operator</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Btn.Equals" parent="Btn.Operator"/>

</resources>
